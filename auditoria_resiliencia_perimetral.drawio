        <mxCell id="ngfw_box" value="🔥 NGFW&#xa;(Next-Gen Firewall)&#xa;&#xa;• Inspección DPI&#xa;• Control de aplicaciones&#xa;• Políticas de acceso&#xa;• Principio mínimo privilegio&#xa;• Reglas: DENY por defecto&#xa;• Solo permite puertos 443/80&#xa;  hacia DMZ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FED7AA;strokeColor=#EA580C;strokeWidth=2;fontSize=9;align=left;spacingLeft=8;" parent="1" vertex="1">
