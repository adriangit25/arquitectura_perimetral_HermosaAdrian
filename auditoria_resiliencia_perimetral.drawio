        <mxCell id="ats_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;strokeWidth=3;fontSize=9;align=left;spacingLeft=8;" value="⚙ ATS&#xa;(Automatic Transfer Switch)&#xa;Transferencia Automática&#xa;&#xa;LÓGICA DE CONMUTACIÓN:&#xa;1. Monitor tensión Red Pública&#xa;2. Si V &lt; 95% → FALLO detectado&#xa;3. Señal arranque → Generador&#xa;4. Espera estabilización (8s)&#xa;5. Conmuta a Generador (Cam. B)&#xa;6. Al restaurar red: retransf. suave&#xa;&#xa;Tiempo total: &lt; 10 segundos&#xa;SIN INTERRUPCIÓN para UPS" vertex="1">
          <mxGeometry height="290" width="230" x="300" y="270" as="geometry" />
        </mxCell>
