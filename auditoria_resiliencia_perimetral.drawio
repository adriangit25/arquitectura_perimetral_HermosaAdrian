        </mxCell>

        <!-- Generador Diésel -->
        <mxCell id="generador" value="🔧 GENERADOR DIÉSEL&#xa;(Camino B — Respaldo)&#xa;&#xa;• 150 kVA / 120 kW&#xa;• Arranque automático&#xa;  en &lt; 10 segundos&#xa;• Tanque: 500L diésel&#xa;  (autonomía 24h)&#xa;• Prueba semanal&#xa;  automatizada" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=3;fontSize=9;align=left;spacingLeft=8;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="420" width="200" height="190" as="geometry"/>
        </mxCell>

        <!-- Flecha Camino A: Red → ATS -->
        <mxCell id="arrow_A_red_ats" value="CAMINO A" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2563EB;strokeWidth=5;fontSize=9;fontColor=#1D4ED8;fontStyle=1;" parent="1" source="red_publica" target="ats_box" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Flecha Camino B: Generador → ATS -->
        <mxCell id="arrow_B_gen_ats" value="CAMINO B" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DC2626;strokeWidth=5;dashed=1;fontSize=9;fontColor=#B91C1C;fontStyle=1;" parent="1" source="generador" target="ats_box" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             ATS — TRANSFERENCIA AUTOMÁTICA
        ══════════════════════════════════════════ -->
        <mxCell id="ats_box" value="⚙ ATS&#xa;(Automatic Transfer Switch)&#xa;Transferencia Automática&#xa;&#xa;LÓGICA DE CONMUTACIÓN:&#xa;1. Monitor tensión Red Pública&#xa;2. Si V &lt; 95% → FALLO detectado&#xa;3. Señal arranque → Generador&#xa;4. Espera estabilización (8s)&#xa;5. Conmuta a Generador (Cam. B)&#xa;6. Al restaurar red: retransf. suave&#xa;&#xa;Tiempo total: &lt; 10 segundos&#xa;SIN INTERRUPCIÓN para UPS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;strokeWidth=3;fontSize=9;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="300" y="270" width="230" height="290" as="geometry"/>
        </mxCell>

        <!-- ══ FLECHA ATS → UPS (ambos caminos se separan aquí) ══ -->
        <mxCell id="arrow_ats_upsA" value="CAMINO A&#xa;(Normal)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2563EB;strokeWidth=5;fontSize=8;fontColor=#1D4ED8;fontStyle=1;" parent="1" source="ats_box" target="ups_a" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="330"/>
              <mxPoint x="590" y="295"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="arrow_ats_upsB" value="CAMINO B&#xa;(Failover)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DC2626;strokeWidth=5;dashed=1;fontSize=8;fontColor=#B91C1C;fontStyle=1;" parent="1" source="ats_box" target="ups_b" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="450"/>
              <mxPoint x="590" y="510"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ══════════════════════════════════════════
             UPS N+1 EN PARALELO (dos unidades)
        ══════════════════════════════════════════ -->
        <mxCell id="ups_zona" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=2;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="560" y="200" width="260" height="410" as="geometry"/>
        </mxCell>
        <mxCell id="ups_zona_label" value="SISTEMA UPS N+1&#xa;(Dos unidades en paralelo — sin SPOF)" style="text;html=1;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=1;fontColor=#166534;" parent="1" vertex="1">
          <mxGeometry x="565" y="205" width="250" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ups_a" value="🔋 UPS-A&#xa;(Camino A — Principal)&#xa;&#xa;• 80 kVA online doble conv.&#xa;• Bat: 15 min a plena carga&#xa;• Conmuta a gen. sin corte&#xa;• Monitor SNMP&#xa;• Rectificador + Inversor&#xa;• Bypass estático interno" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#2563EB;strokeWidth=2;fontSize=9;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="575" y="245" width="230" height="175" as="geometry"/>
        </mxCell>

        <mxCell id="ups_b" value="🔋 UPS-B&#xa;(Camino B — Respaldo N+1)&#xa;&#xa;• 80 kVA online doble conv.&#xa;• Igual capacidad que UPS-A&#xa;• Alimenta si UPS-A falla&#xa;• Monitor SNMP&#xa;• Bypass estático interno&#xa;• Sin SPOF compartido" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;dashed=1;fontSize=9;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="575" y="450" width="230" height="145" as="geometry"/>
        </mxCell>

        <!-- Nota N+1 -->
        <mxCell id="nota_n1" value="N+1: Si UPS-A falla, UPS-B&#xa;asume toda la carga sin&#xa;interrupción. Breakers&#xa;independientes — sin SPOF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;strokeWidth=1;fontSize=8;fontStyle=2;" parent="1" vertex="1">
          <mxGeometry x="565" y="610" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- ══ FLECHAS UPS → PDU ══ -->
        <mxCell id="arrow_upsA_pduA" value="CAMINO A" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2563EB;strokeWidth=5;fontSize=8;fontColor=#1D4ED8;fontStyle=1;" parent="1" source="ups_a" target="pdu_a" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_upsB_pduB" value="CAMINO B" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DC2626;strokeWidth=5;dashed=1;fontSize=8;fontColor=#B91C1C;fontStyle=1;" parent="1" source="ups_b" target="pdu_b" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             PDU — UNIDADES DE DISTRIBUCIÓN DE ENERGÍA
        ══════════════════════════════════════════ -->
        <mxCell id="pdu_a" value="⚡ PDU-A&#xa;(Power Distribution Unit)&#xa;Camino A — Principal&#xa;&#xa;Breakers independientes&#xa;Monitoreo por toma" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#2563EB;strokeWidth=2;fontSize=9;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="880" y="245" width="190" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="pdu_b" value="⚡ PDU-B&#xa;(Power Distribution Unit)&#xa;Camino B — Respaldo&#xa;&#xa;Breakers independientes&#xa;Monitoreo por toma" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;dashed=1;fontSize=9;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="880" y="450" width="190" height="120" as="geometry"/>
        </mxCell>

        <!-- ══ FLECHAS PDU → RACKS ══ -->
        <mxCell id="arrow_pduA_rack" value="CAMINO A → PSU-A" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2563EB;strokeWidth=5;fontSize=8;fontColor=#1D4ED8;fontStyle=1;" parent="1" source="pdu_a" target="rack_main" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow_pduB_rack" value="CAMINO B → PSU-B" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#DC2626;strokeWidth=5;dashed=1;fontSize=8;fontColor=#B91C1C;fontStyle=1;" parent="1" source="pdu_b" target="rack_main" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             RACK DE SERVIDORES (FUENTES DUALES)
        ══════════════════════════════════════════ -->
        <mxCell id="rack_main" value="🖥 RACK DE SERVIDORES&#xa;Centro de Cómputo Institucional&#xa;&#xa;SERVIDOR WEB (DMZ):&#xa;  PSU-A ← Camino A (AZUL)&#xa;  PSU-B ← Camino B (ROJO)&#xa;&#xa;SERVIDOR BD ACADÉMICA:&#xa;  PSU-A ← Camino A (AZUL)&#xa;  PSU-B ← Camino B (ROJO)&#xa;&#xa;SWITCHES / NGFW / IPS:&#xa;  PSU-A ← Camino A&#xa;  PSU-B ← Camino B&#xa;&#xa;⚡ FUENTES DUALES en todos&#xa;los equipos críticos&#xa;&#xa;Si PSU-A falla → PSU-B&#xa;asume SIN interrupción" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#374151;strokeWidth=3;fontSize=9;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="1130" y="230" width="250" height="350" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             ANÁLISIS SPOF
        ══════════════════════════════════════════ -->
        <mxCell id="spof_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="40" y="640" width="1330" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="spof_title" value="VERIFICACIÓN DE ELIMINACIÓN DE SPOF (Single Point of Failure)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1;fontColor=#166534;" parent="1" vertex="1">
          <mxGeometry x="50" y="645" width="1310" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="spof1" value="✅ Red pública falla&#xa;→ ATS activa generador (Cam. B)&#xa;→ Sin corte de servicio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1;fontSize=8;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="50" y="675" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="spof2" value="✅ UPS-A falla&#xa;→ UPS-B (N+1) asume carga&#xa;→ PDU-B alimenta racks&#xa;→ Sin corte de servicio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1;fontSize=8;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="285" y="675" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="spof3" value="✅ PSU-A del servidor falla&#xa;→ PSU-B del mismo servidor&#xa;  asume sin reinicio&#xa;→ Sin corte de servicio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1;fontSize=8;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="520" y="675" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="spof4" value="✅ PDU-A falla&#xa;→ PDU-B alimenta PSU-B&#xa;→ Equipos siguen operando&#xa;→ Sin corte de servicio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1;fontSize=8;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="755" y="675" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="spof5" value="✅ Generador falla (Cam. B)&#xa;→ UPS-A mantiene carga&#xa;  (15 min batería)&#xa;→ Alerta para restaurar red" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1;fontSize=8;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="990" y="675" width="220" height="75" as="geometry"/>
        </mxCell>

        <!-- Nota final Uptime -->
        <mxCell id="nota_final" value="📌 Arquitectura certificable como Uptime Institute Tier III — Disponibilidad 99.982% | Sin SPOF demostrado en los 5 escenarios críticos | Contexto: Racionamientos EMELNORTE Ecuador 2026" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontStyle=2;fontColor=#374151;fillColor=#F9FAFB;strokeColor=#9CA3AF;rounded=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="770" width="1330" height="25" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
